{
  "manifest_version": 3,
  "name": "Semantic Tab Groups",
  "description": "See your open tabs grouped by what they're about, on one scrollable page.",
  "version": "0.2.0",
  "icons": {
    "128": "src/shared/icon-128.png"
  },
  "permissions": [
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "https://api.anthropic.com/*"
  ],
  "background": {
    "service_worker": "src/background/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_title": "Open Tab Groups",
    "default_icon": {
      "128": "src/shared/icon-128.png"
    }
  }
}
