{
  "manifest_version": 3,
  "name": "Semantic Tab Groups",
  "description": "Save tabs to a scrollable groups page, clustered semantically by Claude.",
  "version": "0.3.0",
  "icons": {
    "128": "src/shared/icon-128.png"
  },
  "permissions": [
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "https://api.anthropic.com/*"
  ],
  "action": {
    "default_title": "Tab Groups",
    "default_icon": {
      "128": "src/shared/icon-128.png"
    },
    "default_popup": "src/popup/popup.html"
  }
}
